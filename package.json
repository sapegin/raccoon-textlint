{
  "name": "raccoon-textlint",
  "private": true,
  "description": "Monorepo of Artem Sapegin’s Textlint rules",
  "homepage": "https://github.com/sapegin/raccoon-textlint",
  "license": "MIT",
  "author": {
    "name": "Artem Sapegin",
    "url": "https://sapegin.me"
  },
  "repository": "sapegin/raccoon-textlint",
  "workspaces": [
    "rules/*"
  ],
  "type": "module",
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "oxlint --fix && vitest run",
    "test:watch": "vitest",
    "lint": "oxlint --fix",
    "format": "oxfmt",
    "prepare": "husky"
  },
  "devDependencies": {
    "@textlint/ast-node-types": "15.7.1",
    "@textlint/types": "15.7.1",
    "@types/node": "24.13.2",
    "esbuild": "0.28.1",
    "husky": "9.1.7",
    "nano-staged": "1.0.2",
    "oxfmt": "0.55.0",
    "oxlint": "1.70.0",
    "oxlint-config-raccoon": "10.4.2",
    "oxlint-tsgolint": "0.23.0",
    "textlint-tester": "15.7.1",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "nano-staged": {
    "*.{js,mjs,cjs,ts,tsx}": "oxlint --fix",
    "*.{js,mjs,cjs,ts,tsx,json,jsonc,md}": "oxfmt"
  },
  "engines": {
    "node": ">=24"
  }
}
